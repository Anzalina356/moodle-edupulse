a:90:{s:10:"pluginname";s:8:"AI Grade";s:7:"aigrade";s:8:"AI Grade";s:14:"aigrade_button";s:20:"AI Grade Submissions";s:14:"aigrade_single";s:24:"AI Grade This Submission";s:20:"aigrade_instructions";s:23:"AI Grading Instructions";s:25:"aigrade_instructions_desc";s:56:"Default instructions for the AI when grading assignments";s:9:"no_rubric";s:66:"No PDF rubric found. Please attach a PDF rubric to the assignment.";s:11:"no_ungraded";s:30:"No ungraded submissions found.";s:15:"grading_success";s:39:"Successfully graded {$a} submission(s).";s:13:"grading_error";s:30:"Error grading submission: {$a}";s:8:"ai_error";s:22:"AI service error: {$a}";s:18:"rubric_parse_error";s:30:"Error parsing rubric PDF: {$a}";s:10:"processing";s:13:"Processing...";s:13:"confirm_grade";s:42:"Grade {$a} ungraded submission(s) with AI?";s:28:"privacy:metadata:ai_provider";s:179:"Student submission content is sent to the configured AI provider for grading analysis. This data is processed by the external AI service but not permanently stored by this plugin.";s:43:"privacy:metadata:ai_provider:submissiontext";s:89:"The text content of the student's submission that is sent to the AI provider for grading.";s:43:"privacy:metadata:ai_provider:assignmentname";s:77:"The name of the assignment, sent to provide context to the AI grading system.";s:51:"privacy:metadata:ai_provider:assignmentinstructions";s:77:"The assignment instructions, sent to help the AI understand grading criteria.";s:35:"privacy:metadata:ai_provider:rubric";s:68:"The grading rubric (if uploaded), sent to guide the AI's evaluation.";s:39:"privacy:metadata:ai_provider:gradelevel";s:84:"The student grade level (3-12), sent to help the AI adjust feedback appropriateness.";s:14:"aigrade_rubric";s:14:"Grading rubric";s:19:"aigrade_rubric_help";s:96:"Upload a rubric file (PDF, TXT, DOCX, or DOC) that the AI will use to grade student submissions.";s:12:"aigrade_help";s:77:"Enable AI-assisted grading for this assignment. You must upload a PDF rubric.";s:25:"aigrade_instructions_help";s:135:"Customize the instructions given to the AI when grading submissions. The AI will use these instructions along with the uploaded rubric.";s:17:"no_rubric_warning";s:88:"No rubric found. The AI will grade based on the assignment description and instructions.";s:16:"aigrade_disabled";s:46:"AI grading is not enabled for this assignment.";s:4:"back";s:18:"Back to assignment";s:11:"grade_label";s:6:"Grade:";s:14:"feedback_label";s:9:"Feedback:";s:18:"instructions_label";s:13:"Instructions:";s:20:"grading_rubric_label";s:15:"Grading rubric:";s:29:"assignment_instructions_label";s:24:"Assignment instructions:";s:24:"student_submission_label";s:19:"Student submission:";s:24:"default_grading_criteria";s:98:"Grade this assignment based on standard academic criteria for quality, completeness, and accuracy.";s:19:"pdf_rubric_fallback";s:16:"PDF rubric: {$a}";s:19:"grading_with_rubric";s:61:"You are grading a student assignment using a provided rubric.";s:22:"grading_without_rubric";s:105:"You are grading a student assignment based on the assignment requirements and general academic standards.";s:19:"evaluation_criteria";s:27:"Evaluate the submission on:";s:21:"criteria_completeness";s:55:"Completeness: Did the student address all requirements?";s:16:"criteria_quality";s:48:"Quality: Is the work thorough and well-executed?";s:17:"criteria_accuracy";s:37:"Accuracy: Is the information correct?";s:21:"criteria_presentation";s:45:"Presentation: Is it clear and well-organized?";s:32:"aigrade_instructions_with_rubric";s:37:"Default AI instructions (with rubric)";s:37:"aigrade_instructions_with_rubric_desc";s:138:"Default instructions used when an assignment has a PDF rubric uploaded. This text is copied into new assignments when AI Grade is enabled.";s:35:"aigrade_instructions_without_rubric";s:40:"Default AI instructions (without rubric)";s:40:"aigrade_instructions_without_rubric_desc";s:190:"Default instructions used when an assignment does NOT have a rubric. The AI will grade based on the assignment description. This text is copied into new assignments when AI Grade is enabled.";s:38:"aigrade_instructions_with_rubric_field";s:38:"AI instructions (when rubric uploaded)";s:43:"aigrade_instructions_with_rubric_field_help";s:122:"Instructions for the AI when grading WITH a rubric. The AI will use these instructions along with the uploaded rubric PDF.";s:41:"aigrade_instructions_without_rubric_field";s:32:"AI instructions (when no rubric)";s:46:"aigrade_instructions_without_rubric_field_help";s:128:"Instructions for the AI when grading WITHOUT a rubric. The AI will use these instructions along with the assignment description.";s:11:"grade_level";s:19:"Student grade level";s:16:"grade_level_help";s:144:"Select the grade level of students in this class. The AI will provide age-appropriate feedback and use vocabulary suitable for this grade level.";s:7:"ai_name";s:17:"AI assistant name";s:12:"ai_name_desc";s:168:"Customize the name of the AI grading assistant (e.g., "Boone", "Grady", "Professor AI"). This name will appear on buttons and throughout the interface. Default is "AI".";s:19:"button_grade_single";s:10:"{$a} Grade";s:17:"button_grade_bulk";s:14:"{$a} Grade All";s:23:"google_doc_access_error";s:103:"Could not access Google Doc. Please ensure the document is shared with "Anyone with the link can view".";s:26:"google_slides_access_error";s:110:"Could not access Google Slides. Please ensure the presentation is shared with "Anyone with the link can view".";s:21:"file_extraction_error";s:38:"Could not extract text from file: {$a}";s:21:"unsupported_file_type";s:44:"File type not supported for AI grading: {$a}";s:15:"aigrade_warning";s:18:"AI grading warning";s:20:"aigrade_warning_text";s:182:"<strong>Important:</strong> Always review AI-generated grades and feedback. AI grading works best for text-based assignments and cannot evaluate images, formatting, or visual design.";s:19:"error_no_submission";s:124:"This student has not submitted any text for this assignment yet.  You may need to refresh the page if there is a submission.";s:17:"error_no_feedback";s:26:"AI did not return feedback";s:20:"error_invalid_action";s:14:"Invalid action";s:13:"grade_level_3";s:21:"Grade 3 (Lexile 420L)";s:13:"grade_level_4";s:21:"Grade 4 (Lexile 650L)";s:13:"grade_level_5";s:21:"Grade 5 (Lexile 830L)";s:13:"grade_level_6";s:21:"Grade 6 (Lexile 925L)";s:13:"grade_level_7";s:21:"Grade 7 (Lexile 970L)";s:13:"grade_level_8";s:22:"Grade 8 (Lexile 1010L)";s:13:"grade_level_9";s:22:"Grade 9 (Lexile 1050L)";s:14:"grade_level_10";s:23:"Grade 10 (Lexile 1080L)";s:14:"grade_level_11";s:23:"Grade 11 (Lexile 1185L)";s:14:"grade_level_12";s:23:"Grade 12 (Lexile 1385L)";s:13:"aigrade:grade";s:35:"Use AI to grade student assignments";s:18:"confirm_bulk_grade";s:68:"Grade all ungraded submissions with AI? This may take a few moments.";s:19:"grading_in_progress";s:26:"Grading all submissions...";s:20:"success_graded_count";s:39:"Successfully graded {$a} submission(s).";s:18:"error_with_message";s:11:"Error: {$a}";s:13:"error_unknown";s:22:"Unknown error occurred";s:26:"error_server_communication";s:37:"Error communicating with server: {$a}";s:26:"grading_single_in_progress";s:10:"Grading...";s:18:"grading_strictness";s:18:"Grading strictness";s:23:"grading_strictness_help";s:177:"Control how strictly the AI grades submissions. "Standard" uses grade-level appropriate strictness. Override this if you want easier or harder grading regardless of grade level.";s:23:"strictness_very_lenient";s:44:"Very lenient - reward all reasonable efforts";s:18:"strictness_lenient";s:30:"Lenient - generous with points";s:19:"strictness_standard";s:38:"Standard for grade level (recommended)";s:19:"strictness_rigorous";s:28:"Rigorous - high expectations";s:24:"strictness_very_rigorous";s:39:"Very rigorous - college-level standards";}